generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// This is your strict SQL Table for Contact Form Submissions
model Lead {
  id           Int      @id @default(autoincrement())
  name         String
  email        String
  budget       String?  // The '?' means this field is optional
  requirements String   @db.Text // Uses larger storage for long messages
  createdAt    DateTime @default(now())
}
model Comment {
  id         Int      @id @default(autoincrement())
  author     String
  text       String
  isApproved Boolean  @default(false) // Defaults to false so nothing goes live automatically
  createdAt  DateTime @default(now())
}
model Project {
  id           Int      @id @default(autoincrement())
  title        String
  description  String   @db.Text
  techStack    String   // We'll store this as a comma-separated string like "React, Node, Tailwind"
  imageUrl     String   // Link to the project thumbnail
  liveLink     String?  // Optional: Link to the hosted project
  githubLink   String?  // Optional: Link to the repo
  category     String   @default("Web Development") // e.g., "AI", "Game Dev", "Web"
  createdAt    DateTime @default(now())
}